# Copie este arquivo para .env e ajuste os valores conforme necessário.
# Com os valores padrão o projeto já roda usando SQLite.

# Chave secreta do Django (gere uma nova para produção)
SECRET_KEY=django-insecure-troque-esta-chave-em-producao

# Modo debug: True em desenvolvimento, False em produção
DEBUG=True

# Hosts permitidos, separados por vírgula
ALLOWED_HOSTS=*
